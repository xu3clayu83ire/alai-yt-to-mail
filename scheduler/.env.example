# yt-to-mail 本機排程器環境變數範本
# 複製此檔案為 .env 並填入實際值
# 注意：.env 檔案不得納入版控（已加入 .gitignore）

# AWS 設定
# DynamoDB 資料表所在的 AWS Region
AWS_REGION=ap-northeast-1

# DynamoDB 資料表名稱（須與 CDK Stack 部署的名稱一致）
SUBSCRIPTIONS_TABLE=yt-to-mail-subscriptions
HISTORY_TABLE=yt-to-mail-history

# Gmail API 設定（OAuth2 憑證，從 Google Cloud Console 下載）
# 使用絕對路徑，避免 Windows 工作排程器工作目錄不一致的問題
GMAIL_CREDENTIALS_FILE=C:\path\to\your\credentials.json
GMAIL_TOKEN_FILE=C:\path\to\your\token.json

# 寄件人 Gmail 地址（必須與 OAuth2 授權帳號一致）
GMAIL_SENDER=your-email@gmail.com

# Whisper 語音轉文字模型大小
# 可選值：tiny, base, small, medium, large
# base 在速度與準確度之間取得平衡，適合原型階段
WHISPER_MODEL=base

# yt-dlp 暫存檔案目錄（下載的音訊檔案處理後會自動清除）
YTDLP_OUTPUT_DIR=C:\temp\yt-to-mail

# yt-dlp YouTube cookies 檔案路徑（Netscape 格式 cookies.txt）
# YouTube bot 偵測觸發時需要已登入帳號的 cookie 才能下載
# 匯出方式：在瀏覽器登入 YouTube 後，執行以下指令匯出：
#   yt-dlp --cookies-from-browser chrome --cookies C:\path\to\cookies.txt https://www.youtube.com
# 若不設定則以匿名方式存取（部分影片可能無法下載）
YTDLP_COOKIES_FILE=C:\path\to\cookies.txt

# 前端公開訂閱頁 URL（用於自動取消通知信的重新訂閱連結）
# 部署 CloudFront 後填入實際網址，未設定時通知信改顯示提示文字
FRONTEND_URL=https://xxxxx.cloudfront.net
