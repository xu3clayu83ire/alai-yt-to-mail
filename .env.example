# YouTube Data API v3 金鑰（Google Cloud Console 取得）
YOUTUBE_API_KEY=your_youtube_api_key_here

# 要追蹤的 YouTube 頻道 URL
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@channel/shorts

# OpenAI API 金鑰（用於 Whisper 語音轉文字）
OPENAI_API_KEY=sk-proj-...

# Gmail OAuth 2.0 credentials.json 路徑（相對於 yt-to-mail/ 目錄）
GMAIL_CREDENTIALS_PATH=.source/google_credentials_gmail.json

# Gmail token 快取路徑（首次授權後自動產生）
GMAIL_TOKEN_PATH=.source/gmail_token.json

# 收件信箱
RECIPIENT_EMAIL=your@email.com

# SQLite 資料庫路徑
DB_PATH=data/processed.db

# 音訊語速調整（1.0 = 原速，0.75 = 75% 速度，範圍 0.5~2.0）
AUDIO_SPEED=0.75
